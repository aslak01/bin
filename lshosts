#!/usr/bin/env bash

config_dir=~/.ssh/config.d

if [[ ! -d "$config_dir" ]]; then
  echo "Directory $config_dir does not exist." >&2
  exit 1
fi

for file in "$config_dir"/*; do
  [[ -f "$file" ]] || continue
  while IFS= read -r line; do
    if [[ "$line" =~ ^Host[[:space:]]+([^[:space:]]+) ]]; then
      echo "${BASH_REMATCH[1]}"
    fi
  done <"$file"
done
