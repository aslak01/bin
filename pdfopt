#!/usr/bin/env bash

if [ "$1" = "-ebook" ]; then
    PDF_SETTINGS="/ebook"
    INPUT_FILE="$2"
else
    PDF_SETTINGS="/screen"
    INPUT_FILE="$1"
fi

if [ -z "$INPUT_FILE" ]; then
    echo "Usage: $(basename "$0") [-ebook] <pdf>" >&2
    echo "Compress a PDF with Ghostscript." >&2
    exit 1
fi

if ! command -v gs &>/dev/null; then
    echo "Ghostscript (gs) is not installed. Please install it to use this script." >&2
    exit 1
fi

OUTPUT_FILE="$(dirname "$INPUT_FILE")/optimised-$(basename "$INPUT_FILE")"
gs -sDEVICE=pdfwrite -dCompatibilityLevel=1.4 -dPDFSETTINGS="$PDF_SETTINGS" -dNOPAUSE -dBATCH -sOutputFile="$OUTPUT_FILE" "$INPUT_FILE"
