#!/usr/bin/env bash

if [ -z "$1" ]; then
    echo "Usage: $(basename "$0") <extension>" >&2
    echo "Resize and compress images of a given extension to slugged JPGs." >&2
    exit 1
fi

shopt -s nullglob

for i in *."$1"; do
    slugged=$(slugify "${i%.*}")
    output="$slugged.jpg"
    if [ "$i" != "$output" ]; then
        if sips -Z 1920 -s format jpeg -s formatOptions 90 "$i" --out "$output" >/dev/null; then
            rm "$i"
        fi
    fi
done
