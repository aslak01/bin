#!/usr/bin/env bash

if [ -z "$1" ]; then
    echo "Usage: $(basename "$0") <extension>" >&2
    echo "Resize and compress images of a given extension to slugged JPGs." >&2
    exit 1
fi

if ! command -v magick &>/dev/null; then
    echo "ImageMagick is not installed. Please install it to use this script." >&2
    exit 1
fi

shopt -s nullglob

for i in *."$1"; do
    slugged=$(slugify "${i%.*}")
    output="$slugged.jpg"
    if [ "$i" != "$output" ]; then
        if magick "$i" -resize 1920x1080 -quality 90 "$output"; then
            rm "$i"
        fi
    fi
done
