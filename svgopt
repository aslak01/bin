#!/usr/bin/env bash

if [ -z "$1" ]; then
    echo "Usage: $(basename "$0") <svg>" >&2
    echo "Optimise an SVG and copy the result to the clipboard." >&2
    exit 1
fi

if [ ! -f "$1" ]; then
    echo "Error: File '$1' not found" >&2
    exit 1
fi

if ! command -v svgo &> /dev/null; then
    echo "SVGO is not installed. Please install it to use this script." >&2
    exit 1
fi

if ! command -v pbcopy &> /dev/null; then
    echo "pbcopy is not installed or not available on this system. Please ensure it's installed to copy to clipboard." >&2
    exit 1
fi

input=$1

config_file="${HOME}/.config/svgo.config.js"
if [ -f "$config_file" ]; then
    svgo --config="$config_file" -i "$input" -o - | pbcopy
else
    svgo -i "$input" -o - | pbcopy
fi

echo "Optimized and copied $input (if you provided a valid file). Check clipboard."
