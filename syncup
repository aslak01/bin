#!/usr/bin/env bash

if [[ -z "$1" ]]; then
  echo "Usage: $(basename "$0") <host:path>" >&2
  echo "Push git-tracked files to a remote path via rsync." >&2
  exit 1
fi

if [[ "$1" != *:* ]]; then
  echo "Error: destination must be in host:path format" >&2
  exit 1
fi

rsync -avz --rsync-path="mkdir -p ${1#*:} && rsync" --files-from=<(git ls-files) ./ "$1"
