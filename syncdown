#!/usr/bin/env bash

if [[ -z "$1" ]]; then
  echo "Usage: $(basename "$0") <host:path>" >&2
  echo "Pull git-tracked files from a remote repo via rsync." >&2
  exit 1
fi

host="${1%%:*}"
remote="${1#*:}"
remote_q=$(printf %q "$remote")
# shellcheck disable=SC2029  # $remote_q is intentionally pre-quoted for remote shell
rsync -avz --files-from=<(ssh "$host" "cd $remote_q && git ls-files") "$1/" ./
