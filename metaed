#!/bin/bash

FILE="$1"

if [ -z "$FILE" ]; then
    echo "Usage: $(basename "$0") <video>" >&2
    exit 1
fi

if [ ! -f "$FILE" ]; then
    echo "Error: File '$FILE' not found" >&2
    exit 1
fi

EXT="${FILE##*.}"
TEMP_META=$(mktemp)
TEMP_VIDEO="${FILE%.*}_new.$EXT"

echo "Extracting metadata..."
ffmpeg -i "$FILE" -f ffmetadata - >"$TEMP_META" 2>/dev/null

if [ ! -s "$TEMP_META" ]; then
    cat >"$TEMP_META" <<'EOF'
;FFMETADATA1
title=Movie Title
artist=Director Name
album=Series Name
date=2024
comment=Description here
genre=Action
EOF
fi

"${EDITOR:-vi}" "$TEMP_META"

echo "Applying metadata..."
if ffmpeg -i "$FILE" -i "$TEMP_META" -map_metadata 1 -codec copy "$TEMP_VIDEO"; then
    echo "Success! New file: $TEMP_VIDEO"
    echo "Replace original? (y/n)"
    read -r answer
    if [ "$answer" = "y" ]; then
        mv "$TEMP_VIDEO" "$FILE"
        echo "Original file updated"
    fi
else
    echo "Error applying metadata"
    rm -f "$TEMP_VIDEO"
fi

rm -f "$TEMP_META"
