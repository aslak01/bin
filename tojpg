#!/usr/bin/env bash

if [ -z "$1" ]; then
    echo "Usage: $(basename "$0") <image>" >&2
    echo "Convert an image to JPG." >&2
    exit 1
fi

if [ ! -f "$1" ]; then
    echo "Error: File '$1' not found" >&2
    exit 1
fi

if ! command -v magick &> /dev/null; then
    echo "ImageMagick is not installed. Please install it to use this script." >&2
    exit 1
fi

input_file="$1"
output_file="${input_file%.*}.jpg"

if magick "$input_file" "$output_file"; then
    echo "Conversion successful: $output_file"
else
    echo "Conversion failed for: $input_file" >&2
    exit 1
fi
